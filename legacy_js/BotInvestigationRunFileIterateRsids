// Example 1: Using subtract days mode with full RSID list
async function runWithSubtractDays() {
    const config = {
        toDate: '2025-05-31',
        mode: 'subtractDays',
        subtractDaysValue: 130,  // Will calculate fromDate as toDate - 130 days
        investigationRound: 4.2,
        rsidListPath: './usefulInfo/Legend/botInvestigationMinThresholdVisits.js',
        enableStatusReporting: true,
        statusReportingInterval: 30000  // Report status every 30 seconds
    };

    try {
        const result = await processBotInvestigationRsids(config);
        console.log('\n✨ Processing complete!');
        console.log(`📊 Results:`);
        console.log(`  - Success: ${result.success}`);
        console.log(`  - Processed: ${result.processed}`);
        console.log(`  - Failed: ${result.failed}`);
        console.log(`  - Log file: ${result.logFilePath}`);
        
        if (result.errors.length > 0) {
            console.log('\n❌ Errors encountered:');
            result.errors.forEach(err => {
                console.log(`  - ${err.rsidCleanName} (RSID: ${err.rsid}): ${err.message}`);
            });
        }
    } catch (error) {
        console.error('💥 Fatal error:', error);
        process.exit(1);
    }
}

